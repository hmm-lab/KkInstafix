BOT_TOKEN=your_telegram_bot_token_here

# Optional: set to enable webhook mode (recommended for Railway).
# Use your Railway public URL, e.g. https://your-app.railway.app
WEBHOOK_URL=

# Optional: secret token to verify incoming webhook requests.
# Prevents anyone who guesses the URL from sending fake updates.
WEBHOOK_SECRET=

# Railway sets PORT automatically. Only override if running locally with webhooks.
# PORT=8443
